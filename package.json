{
  "name": "aurealis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev -H 0.0.0.0 -p 3000",
    "dev:admin": "npm run dev --prefix admin",
    "dev:admin:lan": "npm run dev:lan --prefix admin",
    "dev:all:lan": "concurrently -k -n site,admin -c blue,magenta \"npm run dev:lan\" \"npm run dev:admin:lan\"",
    "build": "next build",
    "build:admin": "npm run build --prefix admin",
    "start": "next start",
    "start:lan": "next start -H 0.0.0.0 -p 3000",
    "start:admin": "npm run start --prefix admin",
    "start:admin:lan": "npm run start:lan --prefix admin",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/syne": "^5.2.7",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "next": "16.2.4",
    "next-intl": "^4.9.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
