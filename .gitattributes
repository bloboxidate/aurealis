# Git LFS — large binary assets (see: https://git-lfs.com)
# New commits to these file types are stored via LFS. Existing history is unchanged
# until you run: git lfs migrate import --everything --include="*.png,..." (with care; backup first)

# Raster / web images
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.avif filter=lfs diff=lfs merge=lfs -text
*.ico filter=lfs diff=lfs merge=lfs -text

# Vector / design sources (often large)
*.psd filter=lfs diff=lfs merge=lfs -text
*.ai filter=lfs diff=lfs merge=lfs -text
*.sketch filter=lfs diff=lfs merge=lfs -text

# Video / audio
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.webm filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
*.m4v filter=lfs diff=lfs merge=lfs -text
*.mp3 filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text

# Web fonts
*.woff filter=lfs diff=lfs merge=lfs -text
*.woff2 filter=lfs diff=lfs merge=lfs -text
*.otf filter=lfs diff=lfs merge=lfs -text
*.ttf filter=lfs diff=lfs merge=lfs -text

# Next.js App Router metadata icons must live as plain Git blobs: Vercel (and other
# clones without Git LFS) otherwise receive LFS pointer text and Turbopack fails with
# "Invalid PNG signature" on next build.
app/icon.png -filter -diff -merge
app/apple-icon.png -filter -diff -merge

# Anything under /public is loaded by URL in the browser; LFS pointers break at runtime
# on hosts that clone without Git LFS (e.g. Vercel) — broken logos and static images.
public/**/*.png -filter -diff -merge
public/**/*.jpg -filter -diff -merge
public/**/*.jpeg -filter -diff -merge
public/**/*.webp -filter -diff -merge
public/**/*.gif -filter -diff -merge
public/**/*.ico -filter -diff -merge
public/**/*.avif -filter -diff -merge
